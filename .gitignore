# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# local machine settings
.claude/settings.local.json

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
