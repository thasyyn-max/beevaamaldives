# Copy this file to .env.local and fill in the values.
# With NO values set, the site runs in demo mode (built-in sample data, no admin panel).

# ---------- Supabase (free tier: supabase.com) — enables real data + admin panel
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (Project Settings → API → service_role). KEEP SECRET — server only.
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Cloudinary (free tier: cloudinary.com) — enables photo uploads in admin
# Dashboard → Product environment credentials
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------- Resend (free tier: resend.com) — enables booking emails
RESEND_API_KEY=
# Where new-booking notifications are sent (you / the guesthouse manager)
ADMIN_EMAIL=
# Optional: verified sender, e.g. "Beevaa <bookings@beevaa.com>".
# Defaults to onboarding@resend.dev (testing only — can only email your own Resend account address).
EMAIL_FROM=

# ---------- Site
# Used in emails for links back to the site. Set to your Vercel/domain URL in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
